{
  "functions": {
    "src/app/api/workouts/user-detail/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/workouts/*/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/((?!_next/static|_next/image|favicon.ico).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
}
